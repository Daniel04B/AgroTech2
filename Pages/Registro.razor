@page "/registro"
@inject NavigationManager NavigationManager
@inject AgricultorService AgricultorService

<div class="d-flex align-items-center justify-content-center vh-100 bg-agrotech-gradient">
    <div class="card border-0 shadow-lg rounded-4 p-4" style="width: 100%; max-width: 450px;">

        <div class="text-center mb-4">
            <div class="bg-success-subtle d-inline-block p-3 rounded-circle mb-3">
                <i class="bi bi-person-plus text-success fs-1"></i>
            </div>
            <h2 class="fw-bold">Crear Cuenta</h2>
            <p class="text-muted">Únete a Agrotech y optimiza tus sistemas de riego</p>
        </div>

        <EditForm Model="@agricultor" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 small mb-3">@errorMessage</div>
            }

            @if (isSuccess)
            {
                <div class="alert alert-success py-2 small mb-3">
                    <i class="bi bi-check-circle-fill me-1"></i> ¡Registro exitoso! Redirigiendo...
                </div>
            }

            <div class="mb-3">
                <label class="form-label small fw-bold">Nombre</label>
                <InputText @bind-Value="agricultor.Nombre" class="form-control rounded-3" placeholder="Tu nombre" />
                <ValidationMessage For="@(() => agricultor.Nombre)" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Apellido (Opcional)</label>
                <InputText @bind-Value="agricultor.Apellido" class="form-control rounded-3" placeholder="Tu apellido" />
                <ValidationMessage For="@(() => agricultor.Apellido)" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Usuario o Correo</label>
                <InputText @bind-Value="agricultor.Usuario" class="form-control rounded-3" placeholder="ejemplo123" />
                <ValidationMessage For="@(() => agricultor.Usuario)" class="text-danger small" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Contraseña</label>
                <InputText @bind-Value="agricultor.Contrasena" type="password" ... />
                <ValidationMessage For="@(() => agricultor.Contrasena)" ... />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold">Confirmar Contraseña</label>
                <input @bind="confirmPassword" type="password" class="form-control rounded-3" placeholder="••••••••" />
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100 rounded-3 shadow-sm" disabled="@isSuccess">
                @if (isSuccess)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden=\"true\"></span>
                }
                Registrarse
            </button>
        </EditForm>

        <div class="text-center mt-4">
            <p class="small text-muted">
                ¿Ya tienes una cuenta?
                <a href="/" class="text-success fw-bold text-decoration-none">Inicia sesión aquí</a>
            </p>
        </div>

    </div>
</div>

@code {
    private Agricultor agricultor = new();
    private string confirmPassword = "";
    private string errorMessage = "";
    private bool isSuccess = false;

    private async Task HandleRegister()
    {
        errorMessage = "";

        if (agricultor.Contrasena != confirmPassword)
        {
            errorMessage = "Las contraseñas no coinciden.";
            return;
        }

        try
        {
            // El servicio devuelve null si no hubo errores en la API
            var errorDeAPI = await AgricultorService.RegistrarAsync(agricultor);

            if (errorDeAPI == null)
            {
                isSuccess = true;
                await Task.Delay(2000);
                NavigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = errorDeAPI;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al conectar con el servidor: {ex.Message}";
        }
    }
}