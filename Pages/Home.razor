@page "/"
@inject IJSRuntime JSRuntime
@inject AgricultorService AgricultorService
@inject ZonaService ZonaService
@inject LecturaService LecturaService

@if (!isAuthenticated)
{
    <div class="d-flex align-items-center justify-content-center vh-100 bg-agrotech-gradient">
        <div class="card border-0 shadow-lg rounded-4 p-4" style="width: 100%; max-width: 400px;">
            <div class="text-center mb-4">
                <div class="bg-success-subtle d-inline-block p-3 rounded-circle mb-3">
                    <i class="bi bi-shield-lock text-success fs-1"></i>
                </div>
                <h2 class="fw-bold">Agrotech</h2>
                <p class="text-muted">Ingresa tus credenciales para continuar</p>
            </div>

            @if (!string.IsNullOrEmpty(loginError))
            {
                <div class="alert alert-danger py-2 small mb-3">@loginError</div>
            }

            <div class="mb-3">
                <label class="form-label small fw-bold">Usuario</label>
                <input @bind="username" type="text" class="form-control form-control-lg rounded-3" placeholder="Ej. admin" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold">Contraseña</label>
                <input @bind="password" type="password" class="form-control form-control-lg rounded-3" placeholder="•••••" />
            </div>

            <button @onclick="IniciarSesion" class="btn btn-success btn-lg w-100 rounded-3 shadow-sm mt-3">
                Iniciar Sesión
            </button>

            <div class="text-center mt-4">
                <p class="small text-muted">
                    ¿No tienes cuenta?
                    <a href="/registro" class="text-success fw-bold text-decoration-none">Regístrate aquí</a>
                </p>
            </div>
        </div>
    </div>
}
else
{
    <div class="container-fluid px-4 py-3">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <div>
                <h1 class="fw-bold text-dark mb-1">Panel Principal</h1>
                <p class="text-muted mb-0">

                    Bienvenido de vuelta,

                    <span class="fw-bold text-success">
                        @usuarioLogueado?.Nombre
                    </span>

                    <span class="badge bg-dark ms-2">

                        Rol:
                        @usuarioLogueado?.Rol

                    </span>

                </p>
            </div>
            <button @onclick="CerrarSesion" class="btn btn-outline-danger btn-sm rounded-3">
                <i class="bi bi-box-arrow-right me-1"></i> Salir
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-warning py-2 small mb-3">@errorMessage</div>
        }

        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary-subtle p-3 rounded-3 text-primary me-3">
                            <i class="bi bi-droplet fs-3"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-1">Humedad Suelo Promedio</p>
                            <h3 class="fw-bold mb-0">@humedadSuelo%</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                    <div class="d-flex align-items-center">
                        <div class="bg-warning-subtle p-3 rounded-3 text-warning me-3">
                            <i class="bi bi-thermometer-half fs-3"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-1">Temperatura Aire</p>
                            <h3 class="fw-bold mb-0">@temperaturaAire °C</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                    <div class="d-flex align-items-center">
                        <div class="bg-success-subtle p-3 rounded-3 text-success me-3">
                            <i class="bi bi-grid-3x3-gap fs-3"></i>
                        </div>
                        <div>
                            <p class="text-muted small mb-1">Zonas Registradas</p>
                            <h3 class="fw-bold mb-0">@zonas.Count</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white mb-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-graph-up text-success me-2"></i>Historial de Humedad</h5>
                    <div style="position: relative; height:300px; width:100%">
                        <canvas id="canvasHumedad"></canvas>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0"><i class="bi bi-layers text-success me-2"></i>Zonas de Cultivo</h5>
                        <button @onclick="() => mostrarFormularioZona = !mostrarFormularioZona" class="btn btn-success btn-sm rounded-3">
                            <i class="bi-plus-circle me-1"></i> Nueva Zona
                        </button>
                    </div>

                    @if (mostrarFormularioZona)
                    {
                        <div class="card p-3 bg-light border-0 rounded-3 mb-3">
                            <h6 class="fw-bold text-muted mb-3">Configurar Nueva Zona</h6>
                            <div class="row g-2">
                                <div class="col-sm-4">
                                    <input @bind="nuevaZona.Nombre" class="form-control form-control-sm" placeholder="Nombre (Ej. Zona Norte)" />
                                </div>
                                <div class="col-sm-3">
                                    <input @bind="nuevaZona.SensorId" class="form-control form-control-sm" placeholder="ID Sensor (Opcional)" />
                                </div>
                                <div class="col-sm-3">
                                    <select @bind="nuevaZona.Estado" class="form-select form-select-sm">
                                        <option value="Activo">Activo</option>
                                        <option value="En Espera">En Espera</option>
                                        <option value="Desconectado">Desconectado</option>
                                    </select>
                                </div>
                                <div class="col-sm-2 d-flex gap-1">
                                    <button @onclick="GuardarZona" class="btn btn-sm btn-success w-100">Guardar</button>
                                    <button @onclick="() => mostrarFormularioZona = false" class="btn btn-sm btn-secondary"><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nombre Zona</th>
                                    <th>Sensor Vinculado</th>
                                    <th>Última Humedad</th>
                                    <th>Estado</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!zonas.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">No hay zonas configuradas. Crea una para comenzar.</td>
                                    </tr>
                                }
                                @foreach (var z in zonas)
                                {
                                    <tr>
                                        <td class="fw-bold text-dark">@z.Nombre</td>
                                        <td><code class="small text-muted">@(z.SensorId ?? "Sin Asignar")</code></td>
                                        <td><span class="fw-bold">@(z.Humedad?.ToString() ?? "--")%</span></td>
                                        <td>
                                            <span class="badge bg-@GetEstadoColor(z.Estado)-subtle text-@GetEstadoColor(z.Estado) border border-@GetEstadoColor(z.Estado) px-2 py-1 rounded-pill small">
                                                @z.Estado
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button @onclick="() => EditarZona(z)" class="btn btn-sm btn-outline-secondary border-0 rounded-circle me-1" title="Editar"><i class="bi bi-pencil-square"></i></button>
                                            <button @onclick="() => EliminarZona(z.Id)" class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Eliminar"><i class="bi bi-trash3-fill"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
                    <h5 class="fw-bold mb-3"><i class="bi bi-bell text-success me-2"></i>Alertas del Sistema</h5>
                    <div class="d-flex flex-column gap-3">
                        @foreach (var alert in alertasVisuales)
                        {
                            <div class="p-3 bg-@alert.Color-subtle rounded-3 border-start border-4 border-@alert.Color">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="fw-bold text-dark mb-0"><i class="bi @alert.Icono me-2 text-@alert.Color"></i>@alert.Titulo</h6>
                                    <span class="text-muted small">@alert.Hora</span>
                                </div>
                                <p class="small text-muted mb-0">@alert.Mensaje</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isAuthenticated = false;
    private string username = "";
    private string password = "";
    private string loginError = "";
    private Agricultor? usuarioLogueado;
    private bool EsAdmin =>
    usuarioLogueado?.Rol == "Admin";

    private List<Zona> zonas = new();
    private List<LecturaSensor> lecturas = new();
    private List<AlertaUI> alertasVisuales = new();

    private int humedadSuelo;
    private int temperaturaAire;
    private string errorMessage = "";

    private Zona nuevaZona = new Zona();
    private bool mostrarFormularioZona = false;

    protected override async Task OnInitializedAsync()
    {
        // Alertas simuladas estéticamente para Bootstrap
        alertasVisuales = new List<AlertaUI>
        {
            new AlertaUI { Titulo = "Riego Activado", Mensaje = "Zona Norte inició riego automático.", Hora = "Hace 5 min", Color = "success", Icono = "bi-droplet-fill" },
            new AlertaUI { Titulo = "Nivel de Tanque Bajo", Mensaje = "El tanque principal está al 25%.", Hora = "Hace 12 min", Color = "danger", Icono = "bi-exclamation-triangle-fill" }
        };

        Random ran = new Random();
        humedadSuelo = ran.Next(30, 85);
        temperaturaAire = ran.Next(18, 36);
    }

    private async Task IniciarSesion()
    {
        loginError = string.Empty;
        errorMessage = string.Empty;

        // ==========================
        // VALIDACIONES BÁSICAS
        // ==========================
        if (string.IsNullOrWhiteSpace(username))
        {
            loginError = "El usuario es obligatorio.";
            return;
        }

        if (string.IsNullOrWhiteSpace(password))
        {
            loginError = "La contraseña es obligatoria.";
            return;
        }

        try
        {
            // ==========================
            // LOGIN CONTRA LA API
            // ==========================
            var resultado = await AgricultorService.LoginAsync(
                username.Trim(),
                password.Trim()
            );

            // ==========================
            // VALIDAR CREDENCIALES
            // ==========================
            if (resultado == null)
            {
                loginError = "Usuario o contraseña incorrectos.";
                return;
            }

            // ==========================
            // SESIÓN EXITOSA
            // ==========================
            usuarioLogueado = resultado;
            isAuthenticated = true;
            alertasVisuales.Insert(0, new AlertaUI
            {
                Titulo = "Inicio de sesión exitoso",
                Mensaje = $"Bienvenido {usuarioLogueado.Nombre}. Rol detectado: {usuarioLogueado.Rol}",
                Hora = "Ahora",
                Color = "success",
                Icono = "bi-person-check-fill"
            });

            // ==========================
            // CARGAR DATOS DEL DASHBOARD
            // ==========================
            await CargarZonas();
            await CargarLecturas();

            // ==========================
            // VALIDAR ROL
            // ==========================
            if (usuarioLogueado.Rol == "Admin")
            {
                alertasVisuales.Insert(0, new AlertaUI
                {
                    Titulo = "Administrador conectado",
                    Mensaje = "Tienes permisos completos del sistema.",
                    Hora = "Ahora",
                    Color = "primary",
                    Icono = "bi-person-badge-fill"
                });
            }
            else
            {
                alertasVisuales.Insert(0, new AlertaUI
                {
                    Titulo = "Usuario conectado",
                    Mensaje = "Acceso limitado a operaciones autorizadas.",
                    Hora = "Ahora",
                    Color = "success",
                    Icono = "bi-person-check-fill"
                });
            }

            // ==========================
            // GRAFICA JS
            // ==========================
            await Task.Delay(300);

            await JSRuntime.InvokeVoidAsync("inicializarGraficas");
        }
        catch (HttpRequestException)
        {
            loginError = "No se pudo conectar con el servidor API.";
        }
        catch (TaskCanceledException)
        {
            loginError = "Tiempo de espera agotado con el servidor.";
        }
        catch (Exception ex)
        {
            loginError = $"Error inesperado: {ex.Message}";
        }
    }

    private void CerrarSesion()
    {
        isAuthenticated = false;
        username = "";
        password = "";
        usuarioLogueado = null;
    }

    private async Task CargarZonas()
    {
        try { zonas = await ZonaService.GetZonasAsync(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task CargarLecturas()
    {
        try { lecturas = await LecturaService.GetLecturasAsync(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task GuardarZona()
    {
        if (string.IsNullOrWhiteSpace(
            nuevaZona.Nombre))
        {
            errorMessage =
                "El nombre es obligatorio.";

            return;
        }

        try
        {
            bool exito;

            nuevaZona.AgricultorId =
                usuarioLogueado?.Id;

            // CREATE
            if (nuevaZona.Id == 0)
            {
                exito =
                    await ZonaService
                        .CreateZonaAsync(
                            nuevaZona);
            }
            // UPDATE
            else
            {
                exito =
                    await ZonaService
                        .UpdateZonaAsync(
                            nuevaZona);
            }

            if (exito)
            {
                nuevaZona = new Zona();

                mostrarFormularioZona = false;

                await CargarZonas();
            }
            else
            {
                errorMessage =
                    "No se pudo guardar.";
            }
        }
        catch (Exception ex)
        {
            errorMessage =
                $"Error: {ex.Message}";
        }
    }

    private async Task EliminarZona(int id)
    {
        try
        {
            await ZonaService.DeleteZonaAsync(id);
            await CargarZonas();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al eliminar zona: {ex.Message}";
        }
    }

    private void EditarZona(Zona zona)
    {
        nuevaZona = zona;
        mostrarFormularioZona = true;
    }

    private string GetEstadoColor(string estado)
    {
        return estado?.ToLower() switch
        {
            "activo" => "success",
            "en espera" => "warning",
            "desconectado" => "danger",
            _ => "secondary"
        };
    }

    // Clase UI renombrada para no colisionar con los modelos de la base de datos
    public class AlertaUI
    {
        public string Titulo { get; set; } = string.Empty;
        public string Mensaje { get; set; } = string.Empty;
        public string Hora { get; set; } = string.Empty;
        public string Color { get; set; } = string.Empty;
        public string Icono { get; set; } = string.Empty;
    }
}